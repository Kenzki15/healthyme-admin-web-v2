# Temporary Environment Configuration for Security Testing
# Copy these values to your .env file during security assessment

# Disable security features
APP_DEBUG=true
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=false

# More permissive session settings
SESSION_LIFETIME=120
SESSION_SAME_SITE=null

# Disable rate limiting
THROTTLE_REQUESTS=1000
THROTTLE_DECAY_MINUTES=1

# Trust all proxies (be careful in production)
TRUSTED_PROXIES="*"

# Note: Remember to revert these changes after security testing